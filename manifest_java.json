        "p4": {
            "type": "text",
            "prompt": "Mon prremier est une préposition qui signifie -à l'intérieur de-. Mon second est la planête sur laquelle tu vis...pour l'instant. Mon troisième est le suffixe de ceux qui ne disent pas la vérité. Mon tout est la cérémonie à ton honneur.",
            "attempts": 3,
            "image": "images/coffre.png",
            "routes": {
                "enterrement": "p4",
                "Enterrement": "p4",
                "*": "end_lose"
            }
        },
        "p5": {
            "type": "qcm",
            "prompt": "Choisit la porte qui scellera ton destin !!",
